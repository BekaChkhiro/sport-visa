// Sport Visa — Prisma schema.
//
// Convention: every persisted entity carries `id` (cuid), `createdAt`, and
// `updatedAt` so we never have to bolt timestamps on later. Identity-bearing
// fields (email, etc.) use explicit @unique. Enums replace string statuses
// to keep schema changes auditable via migrations.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  FOOTBALLER
  CLUB
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

// What an uploaded asset is for. Used by the upload presign endpoint to scope
// keys (`<kind>/<id>.<ext>`) and by future feature code to query attachments.
enum MediaKind {
  AVATAR
  GALLERY
  CLUB_LOGO
  CLUB_BANNER
  POST_IMAGE
  CHAT_ATTACHMENT
  OTHER
}

enum NotificationType {
  ACCOUNT_APPROVED
  ACCOUNT_REJECTED
  SERVICE_REQUEST_SUBMITTED
  SERVICE_REQUEST_RESOLVED
  NEW_MESSAGE
  APPLICATION_STATUS
  NEW_CLUB_POST
  GENERAL
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

// Football field positions.
enum Position {
  GK
  CB
  LB
  RB
  CM
  DM
  AM
  LW
  RW
  CF
  ST
}

enum DominantFoot {
  RIGHT
  LEFT
  BOTH
}

enum ExperienceLevel {
  PROFESSIONAL
  SEMI_PROFESSIONAL
  AMATEUR
}

// ── Core models ───────────────────────────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  // Optional first/last names captured at signup so the email-only welcome
  // path has something to greet the user with before profile onboarding.
  firstName     String?
  lastName      String?
  passwordHash  String?
  role          Role
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts          Account[]
  sessions          Session[]
  notifications     Notification[]
  footballerProfile FootballerProfile?
  clubProfile       ClubProfile?

  @@map("users")
}

// NextAuth-managed OAuth account link. Empty in MVP (Credentials provider
// only) but kept on-schema so adding Google OAuth in Phase 3.x is a no-op.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// NextAuth-managed session row. Used only when session strategy = "database".
// We use JWT sessions, so this stays empty in MVP — kept for adapter contract
// and easy swap if we move off JWT later.
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// Single-use tokens for email verification (T3.3) and password reset (T3.4).
// NextAuth's PrismaAdapter writes here directly for the email verification
// flow; we reuse the same table for password reset by prefixing identifier.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// In-app notification record. Created server-side via lib/notifications.ts
// which also fires a Pusher event to the user's private channel.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, read])
  @@map("notifications")
}

// One row per object stored in Cloudflare R2. Created by the /api/uploads/confirm
// endpoint after the client PUTs to the presigned URL. `key` is the bucket-relative
// object key (e.g. `avatar/clx123.jpg`); the read URL is derived from
// R2_PUBLIC_BASE_URL at runtime so it isn't duplicated in the row.
model Media {
  id          String    @id @default(cuid())
  key         String    @unique
  kind        MediaKind
  contentType String
  size        Int
  createdAt   DateTime  @default(now())

  @@index([kind, createdAt])
  @@map("media")
}

// ── Footballer profile ────────────────────────────────────────────────────────

// One FootballerProfile per User with role=FOOTBALLER. Created during onboarding.
// All optional fields may be filled later; `verificationStatus` gates directory
// visibility until admin approves.
model FootballerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal info
  firstName   String
  lastName    String
  dateOfBirth DateTime?
  nationality String? // ISO alpha-2 country code
  city        String?
  country     String? // ISO alpha-2
  phone       String?
  bio         String?   @db.VarChar(500)

  // Sport info
  positions       Position[]
  height          Int? // centimetres
  weight          Int? // kilograms
  dominantFoot    DominantFoot?
  currentClub     String?
  jerseyNumber    Int?
  experienceLevel ExperienceLevel?
  desiredLeague   String?

  // Sports agent / representative contact info.
  agentName  String?
  agentPhone String?
  agentEmail String?

  // Media — R2 keys; the full URL is composed at runtime from R2_PUBLIC_BASE_URL.
  // Gallery photos live in the GalleryItem join table to support ordering.
  avatarKey  String?
  coverKey   String? // hero/banner image shown on the detail page
  videoLinks String[] @default([]) // YouTube / Vimeo URLs, max 3

  // Visibility & verification
  verificationStatus VerificationStatus @default(PENDING)
  rejectionReason    String?
  isVisible          Boolean            @default(true)
  profileViewCount   Int                @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  careerEntries CareerEntry[]
  galleryItems  GalleryItem[]
  shortlistedBy ClubShortlist[]
  subscriptions ClubSubscription[]
  postLikes     PostLike[]

  @@index([verificationStatus, isVisible])
  @@map("footballer_profiles")
}

// One entry per club in the footballer's career history.
model CareerEntry {
  id        String            @id @default(cuid())
  profileId String
  profile   FootballerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  clubName   String
  startYear  Int
  endYear    Int? // null = current
  position   Position?
  orderIndex Int      @default(0) // client-side sort order

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@map("career_entries")
}

// Ordered gallery photo entries for a footballer's profile.
model GalleryItem {
  id        String            @id @default(cuid())
  profileId String
  profile   FootballerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  mediaKey   String // R2 object key
  orderIndex Int    @default(0) // first item is the profile cover photo

  createdAt DateTime @default(now())

  @@index([profileId, orderIndex])
  @@map("gallery_items")
}

// ── Club profile ──────────────────────────────────────────────────────────────

// One ClubProfile per User with role=CLUB. Created during onboarding.
model ClubProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity
  name            String
  foundedYear     Int?
  country         String? // ISO alpha-2
  city            String?
  league          String?
  officialWebsite String?

  // Stadium info
  stadiumName     String?
  stadiumCapacity Int? // seats
  stadiumAddress  String?
  stadiumMapUrl   String? // Google Maps link or coordinates

  // Media — R2 keys
  logoKey  String?
  coverKey String?

  // Rich-text bio / history (rendered as HTML on the detail page)
  bio String? @db.VarChar(2000)

  // Visibility & verification
  verificationStatus VerificationStatus @default(PENDING)
  rejectionReason    String?
  isVisible          Boolean            @default(true)
  profileViewCount   Int                @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rosterEntries      ClubRosterEntry[]
  historyEvents      ClubHistoryEvent[]
  shortlistedPlayers ClubShortlist[]
  subscribers        ClubSubscription[]
  posts              ClubPost[]

  @@index([verificationStatus, isVisible])
  @@map("club_profiles")
}

// Notable milestones / events in a club's history (e.g. trophy wins, founding moments).
// Free-text in MVP; ordered by year then orderIndex.
model ClubHistoryEvent {
  id     String      @id @default(cuid())
  clubId String
  club   ClubProfile @relation(fields: [clubId], references: [id], onDelete: Cascade)

  year        Int
  title       String
  description String?   @db.VarChar(500)
  orderIndex  Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId, year])
  @@map("club_history_events")
}

// Free-text roster entries for a club (MVP: not linked to platform accounts).
model ClubRosterEntry {
  id     String      @id @default(cuid())
  clubId String
  club   ClubProfile @relation(fields: [clubId], references: [id], onDelete: Cascade)

  playerName   String
  position     String?
  jerseyNumber Int?
  orderIndex   Int     @default(0)

  createdAt DateTime @default(now())

  @@index([clubId])
  @@map("club_roster_entries")
}

// ── Social relations ──────────────────────────────────────────────────────────

// A club saves a footballer to their shortlist (★ in the directory).
model ClubShortlist {
  id                  String            @id @default(cuid())
  clubProfileId       String
  footballerProfileId String
  clubProfile         ClubProfile       @relation(fields: [clubProfileId], references: [id], onDelete: Cascade)
  footballerProfile   FootballerProfile @relation(fields: [footballerProfileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([clubProfileId, footballerProfileId])
  @@index([clubProfileId])
  @@index([footballerProfileId])
  @@map("club_shortlists")
}

// A footballer subscribes to a club to receive newsfeed posts on their dashboard.
model ClubSubscription {
  id                  String            @id @default(cuid())
  footballerProfileId String
  clubProfileId       String
  footballerProfile   FootballerProfile @relation(fields: [footballerProfileId], references: [id], onDelete: Cascade)
  clubProfile         ClubProfile       @relation(fields: [clubProfileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([footballerProfileId, clubProfileId])
  @@index([footballerProfileId])
  @@index([clubProfileId])
  @@map("club_subscriptions")
}

// ── Club posts & interactions ─────────────────────────────────────────────────

// A news post created by a club and shown in subscribed footballers' newsfeed.
// `imageKey` is an optional R2 object key for a cover image (kind=POST_IMAGE).
model ClubPost {
  id     String      @id @default(cuid())
  clubId String
  club   ClubProfile @relation(fields: [clubId], references: [id], onDelete: Cascade)

  title    String
  body     String    @db.VarChar(5000)
  imageKey String? // R2 object key; full URL composed from R2_PUBLIC_BASE_URL at runtime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  likes PostLike[]

  @@index([clubId, createdAt])
  @@map("club_posts")
}

// A footballer likes a club's post. One like per footballer per post.
model PostLike {
  id                  String            @id @default(cuid())
  postId              String
  post                ClubPost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  footballerProfileId String
  footballerProfile   FootballerProfile @relation(fields: [footballerProfileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([postId, footballerProfileId])
  @@index([footballerProfileId])
  @@map("post_likes")
}
