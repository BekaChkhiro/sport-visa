# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Project uses npm exclusively — block stray pnpm/yarn artifacts
pnpm-lock.yaml
pnpm-workspace.yaml
yarn.lock

# Build output
.next/
out/
build/
dist/

# Production / runtime
*.tsbuildinfo
next-env.d.ts
.turbo/

# Test output
coverage/
test-results/
playwright-report/
playwright/.cache/

# Env files (never commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
logs/

# IDE / editors
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.fleet/
*.swp
*.swo

# Claude Code — keep shared settings.json, exclude local overrides
.claude/settings.local.json

# OS
.DS_Store
Thumbs.db

# Misc
.eslintcache
.prettiercache
.cache/
*.local
.planflow/
**/.planflow/
