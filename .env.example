# =============================================================================
# Sport Visa — environment variables
# =============================================================================
# Copy this file to `.env.local` for local development:
#   cp .env.example .env.local
#
# Every variable below is validated at boot by `src/lib/env.ts` using zod.
# A missing or malformed value crashes the app immediately with a clear error.
#
# Secret sources by environment:
#   • Local dev → `.env.local` (gitignored, copied from this file)
#   • CI        → GitHub Actions repository / environment secrets
#   • Prod      → Railway service variables (set via the Railway dashboard)
# Never commit real secrets. `.env*` files are gitignored except `.env.example`.
# =============================================================================

# Node runtime mode. Next.js sets this automatically (development | test |
# production) — only override when running scripts outside Next.
NODE_ENV=development

# Public base URL of the deployed app. Inlined into the client bundle at build
# time (any var prefixed with NEXT_PUBLIC_ is exposed to the browser).
#   Local : http://localhost:3000
#   Prod  : https://sport-visa.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL connection string used by Prisma. Server-only — never expose to
# the browser. The default below matches the local docker-compose service.
#   Local : run `docker compose up -d` to start the matching Postgres 16
#   CI    : injected via GitHub Actions secrets
#   Prod  : Railway sets this automatically when a Postgres plugin is attached
DATABASE_URL=postgresql://sport_visa:sport_visa@localhost:5432/sport_visa?schema=public

# -----------------------------------------------------------------------------
# Observability (T1.5) — structured logging + Sentry error tracking.
# All variables below are optional. When unset:
#   • LOG_LEVEL defaults to `debug` in development, `info` in production.
#   • Sentry initialization is skipped (errors still log + return JSON shape).
# See docs/observability.md for log levels, retention, and error JSON shape.
# -----------------------------------------------------------------------------

# Pino log level. One of: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=

# Sentry DSN for server + edge runtimes (Node + Vercel/Edge middleware).
# Server-only — never inlined into the browser bundle.
SENTRY_DSN=

# Sentry DSN exposed to the browser. May equal SENTRY_DSN — set explicitly so
# the build pipeline can swap server vs. client projects if needed.
NEXT_PUBLIC_SENTRY_DSN=

# Environment tag attached to every Sentry event. Defaults to NODE_ENV.
#   e.g. local | preview | production
SENTRY_ENVIRONMENT=

# -----------------------------------------------------------------------------
# Cloudflare R2 storage (T1.6) — S3-compatible object storage for media uploads.
# All variables below are REQUIRED. See docs/r2-storage.md for bucket creation,
# CORS configuration, and custom-domain setup.
# -----------------------------------------------------------------------------

# Cloudflare account ID (32-char hex). Used to derive the S3 endpoint
# `https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com`. Find it on the
# Cloudflare dashboard → R2 → "Use R2 with APIs" panel.
R2_ACCOUNT_ID=

# R2 API token credentials (Object Read & Write scope on the bucket below).
# Create via Cloudflare dashboard → R2 → "Manage R2 API Tokens" → "Create API
# token". Server-only — never inlined into the browser bundle.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Bucket name (lowercase, hyphens). Create one bucket per environment, e.g.
# `sport-visa-dev`, `sport-visa-prod`. Configure CORS to allow PUT from
# NEXT_PUBLIC_APP_URL — see docs/r2-storage.md.
R2_BUCKET=

# Public base URL for objects in the bucket (no trailing slash).
#   • Production: custom domain mapped to the bucket (e.g. https://media.sport-visa.com)
#   • Dev: the bucket's public `*.r2.dev` preview URL (enable in bucket settings)
# Used to build the read URL returned after a successful upload.
R2_PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# Pusher (T1.7) — managed WebSocket for real-time events (chat, notifications).
# All variables below are REQUIRED when real-time features are in use.
# Create a free Channels app at https://pusher.com → Channels → Create app.
# Server secrets stay server-only; NEXT_PUBLIC_* vars are safe for the browser.
# See docs/realtime.md for channel naming conventions and usage patterns.
# -----------------------------------------------------------------------------

# Pusher app credentials — find them in Channels → your app → "App Keys".
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
# Cluster identifier (e.g. eu, ap2, us2). Must match your app's region.
PUSHER_CLUSTER=

# Public-safe Pusher credentials (same values as above — listed separately so
# the build pipeline can verify they're intentionally exposed to the client).
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=
